<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest 
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    ExtensionBundleId="com.xcmotion.quicktoolpro"
    ExtensionBundleVersion="1.0.001" Version="11.0"
    ExtensionBundleName="Quick Tools Pro 2.0"
    >

    <ExtensionList>
        <Extension Id="com.xcmotion.quicktoolpro" Version="1.0.001" />
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <Host Name="AEFT" Version="13.0"/>
        </HostList>

        <LocaleList>
            <Locale Code="All"/>
        </LocaleList>

        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="11.0"/>
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.xcmotion.quicktoolpro">
            <HostList>
                <Host Name="AEFT" Port="8088"/>
            </HostList>
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>./jsx/QuickToolsPro2.0.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--allow-file-access-from-files</Parameter>
                        <Parameter>--allow-file-access</Parameter>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                        <Parameter>--disable-web-security</Parameter>
                    </CEFCommandLine>

                </Resources>

                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                
                    <Type>Panel</Type>
                    <Menu>Quick Tool Pro 2.0</Menu>

                    <Geometry>
                        <Size>
                            <Height>60</Height>
                            <Width>60</Width>
                        </Size>
                        <MinSize>
                            <Width>60</Width>
                            <Height>60</Height>
                        </MinSize>
                        <MaxSize>
                            <Width>1920</Width>
                            <Height>1080</Height>
                        </MaxSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
